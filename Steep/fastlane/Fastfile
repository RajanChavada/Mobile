require "tmpdir"
require "base64"

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    key_path = nil

    begin
      # 1. Generate Xcode project
      sh("xcodegen generate --spec ../project.yml")

      # 2. Setup App Store Connect API Key
      # These secrets should be added to GitHub Actions.
      required_env = %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_CONTENT]
      missing = required_env.select { |k| ENV[k].to_s.strip.empty? }
      UI.user_error!("Missing required env vars: #{missing.join(', ')}") unless missing.empty?

      key_is_base64 = ENV.fetch("ASC_KEY_CONTENT_BASE64", "false").casecmp("true").zero?
      raw_key_content = ENV["ASC_KEY_CONTENT"].to_s.strip
      key_content =
        if raw_key_content.include?("-----BEGIN PRIVATE KEY-----")
          # Accept raw PEM even if the base64 flag is misconfigured.
          raw_key_content.gsub('\n', "\n")
        elsif key_is_base64
          Base64.decode64(raw_key_content)
        else
          raw_key_content.gsub('\n', "\n")
        end
      key_content = "#{key_content.strip}\n"

      unless key_content.include?("-----BEGIN PRIVATE KEY-----") && key_content.include?("-----END PRIVATE KEY-----")
        UI.user_error!("ASC_KEY_CONTENT is invalid. Provide raw .p8 text with BEGIN/END PRIVATE KEY, or set ASC_KEY_CONTENT_BASE64=true only if ASC_KEY_CONTENT is base64 of that full .p8 text.")
      end
      key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV['ASC_KEY_ID']}.p8")
      File.write(key_path, key_content)

      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: key_content,
        is_key_content_base64: false,
        in_house: false
      )

      # 3. Build the app
      build_app(
        scheme: "Steep",
        export_method: "app-store",
        xcargs: "-allowProvisioningUpdates -authenticationKeyPath #{key_path} -authenticationKeyID #{ENV['ASC_KEY_ID']} -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"
      )

      # 4. Upload to TestFlight
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true
      )
    ensure
      File.delete(key_path) if key_path && File.exist?(key_path)
    end
  end
end
