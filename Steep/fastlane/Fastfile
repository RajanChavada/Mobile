default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # 1. Generate Xcode project
    sh("xcodegen generate --spec ../project.yml")

    # 2. Setup App Store Connect API Key
    # These secrets should be added to GitHub Actions.
    required_env = %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_CONTENT]
    missing = required_env.select { |k| ENV[k].to_s.strip.empty? }
    UI.user_error!("Missing required env vars: #{missing.join(', ')}") unless missing.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: ENV.fetch("ASC_KEY_CONTENT_BASE64", "false").casecmp("true").zero?,
      in_house: false
    )

    # 3. Build the app
    build_app(
      scheme: "Steep",
      export_method: "app-store"
    )

    # 4. Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
