require "tmpdir"
require "base64"

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    key_path = nil

    begin
      # 1. Generate Xcode project
      sh("xcodegen generate --spec ../project.yml")

      # 2. Setup App Store Connect API Key
      # These secrets should be added to GitHub Actions.
      required_env = %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_CONTENT]
      missing = required_env.select { |k| ENV[k].to_s.strip.empty? }
      UI.user_error!("Missing required env vars: #{missing.join(', ')}") unless missing.empty?

      ENV["SUPABASE_AUTH_REDIRECT_URL"] = "steep://auth-callback" if ENV["SUPABASE_AUTH_REDIRECT_URL"].to_s.strip.empty?
      UI.message("Backend env presence: SUPABASE_URL=#{ENV['SUPABASE_URL'].to_s.strip.empty? ? 'no' : 'yes'}, SUPABASE_PUBLISHABLE=#{ENV['SUPABASE_PUBLISHABLE'].to_s.strip.empty? ? 'no' : 'yes'}, SUPABASE_AUTH_REDIRECT_URL=#{ENV['SUPABASE_AUTH_REDIRECT_URL'].to_s.strip.empty? ? 'no' : 'yes'}")

      required_backend_env = %w[SUPABASE_URL SUPABASE_PUBLISHABLE]
      missing_backend = required_backend_env.select { |k| ENV[k].to_s.strip.empty? }
      UI.user_error!("Missing required backend env vars: #{missing_backend.join(', ')}") unless missing_backend.empty?

      asc_key_id = ENV["ASC_KEY_ID"].to_s.strip
      asc_issuer_id = ENV["ASC_ISSUER_ID"].to_s.strip

      raw_key_content = ENV["ASC_KEY_CONTENT"].to_s.strip
      candidates = []
      candidates << raw_key_content
      candidates << raw_key_content.gsub('\n', "\n")
      candidates << Base64.decode64(raw_key_content)
      candidates << Base64.decode64(raw_key_content.gsub('\n', "\n"))

      key_content = candidates
        .map { |c| "#{c.to_s.strip}\n" }
        .find { |c| c.include?("-----BEGIN PRIVATE KEY-----") && c.include?("-----END PRIVATE KEY-----") }

      unless key_content
        UI.user_error!("ASC_KEY_CONTENT is invalid. Provide raw .p8 text with BEGIN/END PRIVATE KEY, or set ASC_KEY_CONTENT_BASE64=true only if ASC_KEY_CONTENT is base64 of that full .p8 text.")
      end
      key_path = File.join(Dir.tmpdir, "AuthKey_#{asc_key_id}.p8")
      File.write(key_path, key_content)

      api_key = app_store_connect_api_key(
        key_id: asc_key_id,
        issuer_id: asc_issuer_id,
        key_content: key_content,
        is_key_content_base64: false,
        in_house: false
      )

      xcargs_parts = [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{key_path}",
        "-authenticationKeyID #{asc_key_id}",
        "-authenticationKeyIssuerID #{asc_issuer_id}",
        "SUPABASE_URL=#{ENV['SUPABASE_URL'].to_s.dump}",
        "SUPABASE_PUBLISHABLE=#{ENV['SUPABASE_PUBLISHABLE'].to_s.dump}",
        "SUPABASE_AUTH_REDIRECT_URL=#{ENV['SUPABASE_AUTH_REDIRECT_URL'].to_s.dump}"
      ]

      # 3. Build the app
      build_app(
        scheme: "Steep",
        export_method: "app-store",
        xcargs: xcargs_parts.join(" ")
      )

      # 4. Upload to TestFlight
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true
      )
    ensure
      File.delete(key_path) if key_path && File.exist?(key_path)
    end
  end
end
